/*
 * Virall Nextflow configuration (tools-direct pipeline).
 * Set database paths or VIRALL_DATABASE_DIR for Kaiju/CheckV/VOG.
 */

manifest {
    name        = 'Virall'
    version     = '0.4.0'
    description = 'Viral genome assembly and analysis pipeline'
    mainScript  = 'main.nf'
    homePage    = 'https://github.com/bruPav/Virall'
    nextflowVersion = '>=24.10.0'
}

params {
    samples           = "nextflow/samples.csv"
    outdir            = "results"
    threads           = 8
    memory            = "16G"
    reference         = null
    rna_mode          = false
    assembly_strategy = "hybrid"
    min_contig_len    = 1000
    quality_phred     = 20
    min_read_len      = 50
    min_read_len_long = 1000
    kaiju_db          = null
    checkv_db         = null
    vog_db            = null
}

process {
    maxRetries   = 1
    errorStrategy = 'retry'
    withLabel: preprocess {
        time = '2 h'
        memory = '8 GB'
        cpus = params.threads
    }
    withLabel: host_filter {
        time = '4 h'
        memory = '16 GB'
        cpus = params.threads
    }
    withLabel: assemble {
        time = '24 h'
        memory = 24.GB   // fixed so retries don't double; fits ~31 GB usable RAM
        cpus = params.threads
        maxForks = 2
    }
    withLabel: kaiju {
        time = '4 h'
        memory = '16 GB'
        cpus = params.threads
    }
    withLabel: filter_viral {
        time = '1 h'
        memory = '4 GB'
        cpus = 1
    }
    withLabel: rename_contigs {
        time = '1 h'
        memory = '4 GB'
        cpus = 1
    }
    withLabel: validate {
        time = '2 h'
        memory = '8 GB'
        cpus = params.threads
    }
    withLabel: genomad {
        time = '4 h'
        memory = '16 GB'
        cpus = params.threads
    }
    withLabel: merge_quality {
        time = '1 h'
        memory = '4 GB'
        cpus = 1
    }
    withLabel: annotate {
        time = '4 h'
        memory = '8 GB'
        cpus = params.threads
    }
    withLabel: quantify {
        time = '2 h'
        memory = '8 GB'
        cpus = params.threads
    }
    withLabel: reference_check {
        time = '4 h'
        memory = '16 GB'
        cpus = params.threads
    }
    withLabel: plot {
        time = '1 h'
        memory = '4 GB'
        cpus = 1
    }
    withLabel: single_cell {
        time = '12 h'
        memory = '8 GB'
        cpus = params.threads
    }
}

profiles {
    local { executor = 'local' }

    // Docker: all processes run in the virall Docker image.
    // Nextflow automatically mounts the work dir; helper scripts are staged as inputs.
    docker {
        docker.enabled = true
        docker.runOptions = '--entrypoint ""'
        process.container = 'pavle17/virall'
        params.kaiju_db = '/opt/virall/databases/kaiju_db'
        params.checkv_db = '/opt/virall/databases/checkv_db'
        params.genomad_db = '/opt/virall/databases/genomad_db'
        params.vog_db = '/opt/virall/databases/vog_db'
    }

    // Singularity: same DB location /opt/virall/databases/ (image includes tools + DBs).
    // Nextflow automatically mounts the work dir; helper scripts are staged as inputs.
    singularity {
        singularity.enabled = true
        process.container = "library://brupav/virall/virall:latest"
        params.kaiju_db = '/opt/virall/databases/kaiju_db'
        params.checkv_db = '/opt/virall/databases/checkv_db'
        params.genomad_db = '/opt/virall/databases/genomad_db'
        params.vog_db = '/opt/virall/databases/vog_db'
    }

    slurm {
        executor = 'slurm'
        queue = 'normal'
        clusterOptions = '-A your_account'
    }
    sge {
        executor = 'sge'
        queue = 'all.q'
    }
}
